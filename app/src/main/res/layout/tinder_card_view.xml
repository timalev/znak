<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="350dp"
    android:layout_height="425dp"
    android:layout_marginBottom="50dp"
    android:orientation="vertical">
    <android.support.v7.widget.CardView
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        app:cardCornerRadius="7dp"
        app:cardElevation="4dp">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible" />


        <ImageView
            android:visibility="gone"
            android:id="@+id/nopho"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/noavatar" />

        <ImageView

            android:id="@+id/profileImageView"
            android:scaleType="centerCrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="75dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:orientation="vertical"
            android:layout_gravity="bottom"
            android:gravity="center|left"
            android:paddingLeft="20dp">


            <TextView
                android:id="@+id/nameAgeTxt"
                android:layout_width="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="18dp"
                android:textStyle="bold"
                android:layout_height="wrap_content"/>


            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                >
                <TextView
                    android:id="@+id/locationNameTxt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.45"

                    />

                <TextView
                    android:id="@+id/towrite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.35"
                    android:textColor="#005FC1"
                    android:visibility="gone"
                    android:text="Написать"

                    />

                <ImageView
                    android:id="@+id/s_like"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:gravity="right"
                    android:src="@drawable/black_h2"
                    android:layout_weight="0.1"/>

                <TextView
                    android:id="@+id/lukosov"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:layout_weight="0.1"

                    />





            </LinearLayout>






        </LinearLayout>


































        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:visibility="gone"
            android:orientation="vertical"
            android:layout_gravity="bottom"
            android:gravity="center|left"
            android:paddingLeft="20dp">
            <TextView
                android:id="@+id/nameAgeTxt2"
                android:layout_width="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="18dp"
                android:textStyle="bold"
                android:layout_height="wrap_content"/>



            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="#FFFFFF">


                <TextView  android:id="@+id/locationNameTxt22"
                    android:paddingLeft="0dp"
                    android:layout_gravity="left"
                    android:gravity="left"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="14dp"
                    android:textStyle="normal"
                    android:layout_width="fill_parent"
                    android:layout_height="50dp"
                    android:layout_weight="0.9"
                   />

                <TextView  android:id="@+id/lukosov33"
                    android:paddingLeft="1dp"
                    android:layout_gravity="right"
                    android:gravity="right"
                    android:textSize="16dp"
                    android:textColor="#000000"
                    android:textStyle="normal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.93"
                    android:paddingRight="10dp"
                    android:text="0"/>
                <ImageView
                    android:paddingRight="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"

                    android:src="@drawable/black_h"
                    android:layout_weight="0.07"/>

            </LinearLayout>






        </LinearLayout>
    </android.support.v7.widget.CardView>
</FrameLayout>