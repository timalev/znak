<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Поле ввода телефона -->
    <EditText
        android:id="@+id/apho"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:hint="+7 (999) 000-00-00"
        android:inputType="phone"
        android:padding="16dp"
        android:textSize="18sp" />

    <!-- Поле ввода кода (скрыто) -->
    <EditText
        android:id="@+id/acod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:hint="Код из SMS"
        android:inputType="number"
        android:maxLength="6"
        android:padding="16dp"
        android:textSize="18sp"
        android:visibility="gone" />

    <!-- Кнопка отправить код -->
    <Button
        android:id="@+id/sendcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/apho"
        android:layout_marginTop="16dp"
        android:text="Отправить код" />

    <!-- Кнопка подтвердить код (скрыта) -->
    <Button
        android:id="@+id/incode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/acod"
        android:layout_marginTop="16dp"
        android:text="Подтвердить"
        android:visibility="gone" />

    <!-- Статус -->
    <TextView
        android:id="@+id/sev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/incode"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:textColor="@android:color/holo_blue_dark"
        android:visibility="gone" />

    <!-- Повторная отправка -->
    <TextView
        android:id="@+id/resendcode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/sev"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Отправить код повторно"
        android:textColor="@android:color/holo_blue_dark"
        android:visibility="gone" />

    <!-- Демо вход -->
    <TextView
        android:id="@+id/demotxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/resendcode"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="Демо вход (7777777777)"
        android:textColor="@android:color/holo_green_dark"
        android:visibility="visible" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBarAuth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- Текст о разрешениях -->
    <TextView
        android:id="@+id/permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="Недостаточно разрешений для запуска приложения"
        android:textColor="#000ecd"
        android:visibility="gone" />

    <!-- Текст бана -->
    <TextView
        android:id="@+id/ban_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/permissions"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:textColor="@android:color/holo_red_dark"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

</RelativeLayout>